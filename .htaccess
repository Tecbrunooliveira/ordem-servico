DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /osv2/

    # Arquivos estáticos dentro de public/ (Livewire é rota dinâmica — não incluir aqui)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(build|css|js|fonts|storage|vendor|wireui)/(.*)$ public/$1/$2 [L]

    # Demais rotas → index.php na raiz
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [L]
</IfModule>
