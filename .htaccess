DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Arquivos estáticos dentro de public/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(build|css|js|fonts|storage|vendor|wireui|livewire[^/]*)/(.*)$ public/$1/$2 [L]

    # Demais rotas → index.php na raiz
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [L]
</IfModule>
